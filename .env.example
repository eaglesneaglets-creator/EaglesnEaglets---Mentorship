# =============================================================================
# Eagles & Eaglets — Frontend Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.
# For Railway: set these in the Railway dashboard → Frontend Service → Variables.
# All variables MUST start with VITE_ to be accessible in browser code.
# =============================================================================

# =============================================================================
# API
# The base URL of your Railway backend service (no trailing slash)
# Railway frontend service: set this to your backend Railway URL
# =============================================================================
VITE_API_URL=https://your-backend-name.up.railway.app

# =============================================================================
# WEBSOCKET
# WebSocket base URL — use wss:// in production (Railway handles TLS termination)
# =============================================================================
VITE_WS_URL=wss://your-backend-name.up.railway.app

# =============================================================================
# PAYMENT — Paystack Public Key
# Get from: https://dashboard.paystack.com/#/settings/developer
# Use pk_test_... for staging, pk_live_... for production
# IMPORTANT: This is the PUBLIC key only — never put the secret key here
# =============================================================================
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here

# =============================================================================
# ERROR MONITORING — Sentry (optional but recommended for production)
# Get from: https://sentry.io → New Project → React
# =============================================================================
VITE_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/your-project-id
